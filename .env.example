# Copy this file to `.env` in the repo root and fill in values.
# `.env` is gitignored — never commit it.
#
#   copy .env.example .env        (Windows cmd)
#   Copy-Item .env.example .env     (PowerShell)
#
# Used by: scripts/run_live_ac_trials.py, crossfire-forge review --provider mixed

# Required for full mixed roster (Vertex flash + pro + Anthropic Sonnet).
# Without this, pass --allow-vertex-only for degraded Vertex-only mode.
ANTHROPIC_API_KEY=

# Optional — Vertex overrides (defaults: gcloud ADC project/region, gemini-2.5-flash)
# VERTEX_PROJECT=
# VERTEX_LOCATION=us-central1
# VERTEX_MODEL=gemini-2.5-flash
